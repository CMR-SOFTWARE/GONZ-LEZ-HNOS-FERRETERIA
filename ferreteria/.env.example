# SEPARACIÓN DE ENTORNOS
# ─────────────────────────────────────────────────────────────────────────────
# .env.local (este archivo, NO se commitea) → apuntar al proyecto Supabase DEV
#   Crear un proyecto gratuito en supabase.com (ej: ferreteria-dev), ejecutar
#   supabase-schema.sql en su SQL Editor, y usar sus credenciales aquí.
#
# Producción (Netlify/Vercel) → configurar las variables en el dashboard del
#   hosting (Site settings → Environment variables) con el proyecto Supabase
#   de producción. El build de Netlify/Vercel usa esas variables; nunca toca
#   este archivo. Así localhost y producción quedan completamente separados.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase → Project Settings → API (misma pestaña para URL y claves)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# La clave "anon" "public" es un JWT largo que empieza con eyJ (no uses texto tipo PASTE_...).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Admin: crear usuario en Authentication; luego en SQL Editor:
# insert into public.app_admins (user_id) values ('<uuid del usuario>');
# Migrar fotos base64 → Storage (una vez, más rápido el catálogo):
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   (Settings → API → service_role, solo en local)
# npm run migrate-images
# Antes ejecutá supabase-storage-products.sql en SQL Editor.

# Si la base ya existía con políticas viejas, ejecutá supabase-migration-to-admin-auth.sql
# Producción: Authentication → Providers → desactivá el registro público si no lo necesitás.
